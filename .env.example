# =============================================================================
# AMEEK - Environment Variables Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,your-domain.com

# --- Database ---
# SQLite (local dev)
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (production - uncomment and fill)
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require

# --- Email (SMTP - Brevo / Sendinblue) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=AMEEK <noreply@ameek.sn>
BASE_URL=http://127.0.0.1:8000

# --- Admin ---
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@ameek.sn
ADMIN_PASSWORD=set-a-strong-password-here

# --- PayDunya (payment gateway) ---
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test

# --- CSRF ---
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000
